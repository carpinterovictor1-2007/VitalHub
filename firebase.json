{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      "database.rules.json",
      "firebase-init.js",
      "server.js",
      "setup.ps1",
      "start.ps1",
      ".env",
      "vitalhub.db",
      "**/.*",
      "**/node_modules/**",
      "package.json",
      "package-lock.json"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      }
    ]
  }
}
